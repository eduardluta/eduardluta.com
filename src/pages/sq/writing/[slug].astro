---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleView from '../../../components/views/ArticleView.astro';
import { useTranslations, SITE_NAME } from '../../../i18n/ui';
import { localizePath, isoDate } from '../../../i18n/utils';
import { SITE } from '../../../consts';
import { getArticles, firstBodyImage, countWords, type Article } from '../../../lib/writing';
import { articleSchema, breadcrumbSchema } from '../../../lib/schema';

export const getStaticPaths = (async () => {
  const articles = await getArticles('sq');
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}) satisfies GetStaticPaths;

interface Props {
  article: Article;
}
const { article } = Astro.props;
const lang = 'sq';
const t = useTranslations(lang);

const url = new URL(localizePath(`/writing/${article.slug}/`, lang), SITE).href;
const published = isoDate(article.data.date);
const modified = article.data.updated ? isoDate(article.data.updated) : undefined;
// Social cards keep the 1200x630 default unless an explicit heroImage is set
// (body images are mostly small/portrait); JSON-LD gets the real article image.
const cardImage = article.data.heroImage ?? '/og-default.png';
const schemaImage = new URL(
  article.data.heroImage ?? firstBodyImage(article.body) ?? '/og-default.png',
  SITE
).href;
---

<BaseLayout
  lang={lang}
  wide
  title={`${article.data.title} — ${SITE_NAME}`}
  description={article.data.description}
  ogType="article"
  image={cardImage}
  imageAlt={article.data.heroImage ? article.data.heroImageAlt ?? article.data.title : undefined}
  publishedTime={published}
  modifiedTime={modified}
  pageSchema={{ mainEntity: { '@id': `${url}#article` } }}
  jsonLd={[
    articleSchema({
      title: article.data.title,
      description: article.data.description,
      url,
      datePublished: published,
      dateModified: modified,
      lang,
      image: schemaImage,
      wordCount: countWords(article.body),
      tags: article.data.tags,
    }),
    breadcrumbSchema([
      { name: SITE_NAME, url: localizePath('/', lang) },
      { name: t('writing.title'), url: localizePath('/writing/', lang) },
      { name: article.data.title, url: localizePath(`/writing/${article.slug}/`, lang) },
    ]),
  ]}
>
  <ArticleView lang={lang} article={article} />
</BaseLayout>
