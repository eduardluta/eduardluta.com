---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomeView from '../../components/views/HomeView.astro';
import { useTranslations, SITE_NAME } from '../../i18n/ui';
import { SITE } from '../../consts';
import { getArticles } from '../../lib/writing';

const lang = 'sq';
const t = useTranslations(lang);
const articles = await getArticles(lang);
---

<BaseLayout
  lang={lang}
  title={`${SITE_NAME} — ${t('site.tagline')}`}
  description={t('site.description')}
  pageSchema={{ '@type': 'ProfilePage', mainEntity: { '@id': `${SITE}/#person` } }}
>
  <HomeView lang={lang} articles={articles} />
</BaseLayout>
