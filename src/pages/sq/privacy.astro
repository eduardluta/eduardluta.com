---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LegalView from '../../components/views/LegalView.astro';
import { SITE_NAME } from '../../i18n/ui';
import { privacy } from '../../data/legal';

const lang = 'sq';
---

<BaseLayout lang={lang} title={`${privacy.title[lang]} — ${SITE_NAME}`} description={privacy.description[lang]}>
  <LegalView lang={lang} doc={privacy} />
</BaseLayout>
