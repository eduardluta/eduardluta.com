---
import { ClientRouter } from 'astro:transitions';
import '@fontsource/ibm-plex-mono/300.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
// IBM Plex Serif — the long-form reading face for article bodies (same type family).
import '@fontsource/ibm-plex-serif/400.css';
import '@fontsource/ibm-plex-serif/400-italic.css';
import '@fontsource/ibm-plex-serif/600.css';
import '@fontsource/ibm-plex-serif/600-italic.css';
import '../styles/global.css';

import { SITE } from '../consts';
import { SITE_NAME, X_HANDLE, useTranslations, type Lang } from '../i18n/ui';
import { resolveAlternates } from '../lib/writing';
import { personSchema, websiteSchema } from '../lib/schema';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsletterPopup from '../components/NewsletterPopup.astro';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  image?: string;
  /** Alt text for the OG/Twitter card image. */
  imageAlt?: string;
  publishedTime?: string;
  modifiedTime?: string;
  /** Page-specific JSON-LD nodes (no '@context'; merged into the page @graph). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Overrides merged into the page's WebPage node (e.g. '@type': 'ProfilePage'). */
  pageSchema?: Record<string, unknown>;
  noindex?: boolean;
  /** Widen the content column (used by the article reader). */
  wide?: boolean;
}

const {
  lang,
  title,
  description,
  ogType = 'website',
  image = '/og-default.png',
  imageAlt = `${SITE_NAME} — personal site`,
  publishedTime,
  modifiedTime,
  jsonLd,
  pageSchema,
  noindex = false,
  wide = false,
} = Astro.props;

const pathname = Astro.url.pathname;
const canonical = new URL(pathname, SITE).href;
const alternates = await resolveAlternates(pathname);
const enHref = alternates.en ? new URL(alternates.en, SITE).href : null;
const sqHref = alternates.sq ? new URL(alternates.sq, SITE).href : null;
const xDefaultHref = enHref ?? sqHref;
const hasOtherLocale = lang === 'en' ? Boolean(sqHref) : Boolean(enHref);
const ogImage = new URL(image, SITE).href;
// The default card is a known 1200x630 render; per-article images vary, so only
// declare dimensions we actually know.
const isDefaultOgImage = image === '/og-default.png';

const ogLocale = lang === 'sq' ? 'sq_AL' : 'en_US';
const ogLocaleAlt = lang === 'sq' ? 'en_US' : 'sq_AL';

// Single JSON-LD @graph per page: WebPage + WebSite + Person on every page, plus
// whatever the page passes in (article, breadcrumbs, ...). '@context' is stripped
// from passed nodes defensively — the wrapper supplies it once.
const jsonLdList = (jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []).map(
  ({ '@context': _context, ...node }) => node
);
const webPageNode = {
  '@type': 'WebPage',
  '@id': `${canonical}#webpage`,
  url: canonical,
  name: title,
  description,
  inLanguage: lang,
  isPartOf: { '@id': `${SITE}/#website` },
  ...pageSchema,
};
const graph = {
  '@context': 'https://schema.org',
  '@graph': [webPageNode, websiteSchema(), personSchema(), ...jsonLdList],
};

const rssHref = lang === 'sq' ? '/sq/rss.xml' : '/rss.xml';
const rssTitle = lang === 'sq' ? `${SITE_NAME} — Shkrime` : `${SITE_NAME} — Writing`;

const bingVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION;
const googleVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE_NAME} />
    <meta
      name="robots"
      content={noindex
        ? 'noindex, nofollow'
        : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
    />
    {bingVerification && <meta name="msvalidate.01" content={bingVerification} />}
    {googleVerification && <meta name="google-site-verification" content={googleVerification} />}

    {!noindex && <link rel="canonical" href={canonical} />}
    {!noindex && enHref && <link rel="alternate" hreflang="en" href={enHref} />}
    {!noindex && sqHref && <link rel="alternate" hreflang="sq" href={sqHref} />}
    {!noindex && xDefaultHref && <link rel="alternate" hreflang="x-default" href={xDefaultHref} />}
    <link rel="alternate" type="application/rss+xml" title={rssTitle} href={rssHref} />

    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <!-- Media-paired defaults for first paint; the inline script below keeps both
         in sync with the active data-theme (manual override included). -->
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f7f4ee" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#15130f" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {isDefaultOgImage && <meta property="og:image:width" content="1200" />}
    {isDefaultOgImage && <meta property="og:image:height" content="630" />}
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content={ogLocale} />
    {hasOtherLocale && <meta property="og:locale:alternate" content={ogLocaleAlt} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={X_HANDLE} />
    <meta name="twitter:creator" content={X_HANDLE} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <script type="application/ld+json" set:html={JSON.stringify(graph)} />

    <!-- Google Analytics (gtag.js) — production only, so local/dev visits never
         pollute the data. SPA navigations (Astro view transitions) are captured
         by GA4 enhanced measurement's history-change tracking. -->
    {import.meta.env.PROD && (
      <>
        <link rel="preconnect" href="https://www.googletagmanager.com" />
        <link rel="dns-prefetch" href="https://www.google-analytics.com" />
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-61J937ZMBP"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-61J937ZMBP');
        </script>
      </>
    )}

    <!-- No-flash theme: applied before first paint AND re-applied after every
         view-transition swap (which resets <html> attributes). -->
    <script is:inline>
      (function () {
        function applyTheme() {
          var dark;
          try {
            var stored = localStorage.getItem('el-theme');
            dark = stored
              ? stored === 'dark'
              : window.matchMedia('(prefers-color-scheme: dark)').matches;
          } catch (e) {
            dark = false;
          }
          document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
          document.querySelectorAll('meta[name="theme-color"]').forEach(function (meta) {
            meta.setAttribute('content', dark ? '#15130f' : '#f7f4ee');
          });
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#main-content">{t('nav.skip')}</a>
    <div class="shell">
      <div class:list={['wrap', { 'wrap--wide': wide }]}>
        <Header lang={lang} />
        <main class="main" id="main-content" tabindex="-1">
          <slot />
        </main>
        <Footer lang={lang} />
      </div>
    </div>
    <NewsletterPopup lang={lang} />

    <script>
      import { initApp } from '../scripts/app';
      // Runs on first load and after every view transition.
      document.addEventListener('astro:page-load', initApp);
    </script>
  </body>
</html>
