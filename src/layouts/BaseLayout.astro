---
import { ClientRouter } from 'astro:transitions';
import '@fontsource/ibm-plex-mono/300.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
import '../styles/global.css';

import { SITE } from '../consts';
import { SITE_NAME, useTranslations, type Lang } from '../i18n/ui';
import { getAlternates } from '../i18n/utils';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsletterPopup from '../components/NewsletterPopup.astro';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  image?: string;
  publishedTime?: string;
  modifiedTime?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const {
  lang,
  title,
  description,
  ogType = 'website',
  image = '/og-default.png',
  publishedTime,
  modifiedTime,
  jsonLd,
  noindex = false,
} = Astro.props;

const pathname = Astro.url.pathname;
const canonical = new URL(pathname, SITE).href;
const alternates = getAlternates(pathname);
const enHref = new URL(alternates.en, SITE).href;
const sqHref = new URL(alternates.sq, SITE).href;
const ogImage = new URL(image, SITE).href;

const ogLocale = lang === 'sq' ? 'sq_AL' : 'en_US';
const ogLocaleAlt = lang === 'sq' ? 'en_US' : 'sq_AL';

const jsonLdList = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE_NAME} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="sq" href={sqHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <!-- Kept in sync with the active data-theme by the inline script below. -->
    <meta name="theme-color" content="#f7f4ee" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {jsonLdList.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}

    <!-- No-flash theme: applied before first paint AND re-applied after every
         view-transition swap (which resets <html> attributes). -->
    <script is:inline>
      (function () {
        function applyTheme() {
          var dark;
          try {
            var stored = localStorage.getItem('el-theme');
            dark = stored
              ? stored === 'dark'
              : window.matchMedia('(prefers-color-scheme: dark)').matches;
          } catch (e) {
            dark = false;
          }
          document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
          var meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute('content', dark ? '#15130f' : '#f7f4ee');
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#main-content">{t('nav.skip')}</a>
    <div class="shell">
      <div class="wrap">
        <Header lang={lang} />
        <main class="main" id="main-content" tabindex="-1">
          <slot />
        </main>
        <Footer lang={lang} />
      </div>
    </div>
    <NewsletterPopup lang={lang} />

    <script>
      import { initApp } from '../scripts/app';
      // Runs on first load and after every view transition.
      document.addEventListener('astro:page-load', initApp);
    </script>
  </body>
</html>
