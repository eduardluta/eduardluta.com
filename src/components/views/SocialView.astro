---
import { social, useTranslations, type Lang } from '../../i18n/ui';
import { getSocialFeed } from '../../lib/social';
import SocialCard from '../SocialCard.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const posts = getSocialFeed();
---

<h1 class="view-title">{t('social.title')}</h1>
<p class="view-sub" style="margin-bottom:28px">{t('social.subtitle')}</p>

{posts.length > 0 ? (
  <div class="wall">
    {posts.map((post) => <SocialCard post={post} lang={lang} />)}
  </div>
) : (
  <p class="view-sub">
    <a href={social.x} target="_blank" rel="noopener noreferrer me">X</a>
    {' · '}
    <a href={social.tiktok} target="_blank" rel="noopener noreferrer me">TikTok</a>
    {' · '}
    <a href={social.instagram} target="_blank" rel="noopener noreferrer me">Instagram</a>
    {' · '}
    <a href={social.linkedin} target="_blank" rel="noopener noreferrer me">LinkedIn</a>
  </p>
)}
