# Railway Postgres connection string used by the newsletter function
# (netlify/functions/subscribe.mjs).
#
# Do NOT commit the real value. Set it in Netlify:
#   Site settings → Environment variables → DATABASE_URL
#
# Locally, copy this file to `.env` for `netlify dev`.
DATABASE_URL="postgresql://user:password@host:5432/railway"

# --- Live social wall (Instagram + TikTok) ---------------------------------
# Optional. Without these, the social wall shows the curated fallback posts.
# Set them in Netlify → Environment variables so the build fetches real posts.

# Long-lived Instagram Graph API access token.
INSTAGRAM_TOKEN=""
# Optional IG Business account id. If set, queries graph.facebook.com/{id}/media;
# otherwise graph.instagram.com/me/media.
INSTAGRAM_USER_ID=""

# TikTok Display API user access token (scope: video.list).
TIKTOK_TOKEN=""

# Optional counts (defaults: 6 IG, 4 TikTok).
SOCIAL_IG_LIMIT="6"
SOCIAL_TT_LIMIT="4"

# Netlify build-hook URL, used by the daily scheduled function to rebuild and
# refresh the feed (Netlify → Site configuration → Build hooks).
NETLIFY_BUILD_HOOK=""
