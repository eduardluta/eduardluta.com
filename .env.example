# Railway Postgres connection string. Powers the newsletter API
# (src/pages/api/subscribe.ts) and the TikTok refresh-token store.
#
# On Railway, reference the Postgres service's internal URL so traffic stays on
# the private network (no TLS, faster): DATABASE_URL = ${{ Postgres.DATABASE_URL }}
#
# Do NOT commit the real value. Locally, copy this file to `.env`; use the
# Postgres *public* URL for local runs.
DATABASE_URL="postgresql://user:password@host:5432/railway"

# --- Live social wall (Instagram + TikTok) ---------------------------------
# Optional. Without these, the social wall shows the curated fallback posts.
# Set them in Netlify → Environment variables so the build fetches real posts.

# Long-lived Instagram Graph API access token.
INSTAGRAM_TOKEN=""
# Optional IG Business account id. If set, queries graph.facebook.com/{id}/media;
# otherwise graph.instagram.com/me/media.
INSTAGRAM_USER_ID=""

# TikTok Display API. Access tokens expire in ~24h, so we use the refresh-token
# flow: run `npm run tiktok:auth` to obtain TIKTOK_REFRESH_TOKEN (valid ~365d),
# and the build mints a fresh access token each time.
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_REDIRECT_URI="https://eduardluta.com/"
TIKTOK_REFRESH_TOKEN=""
# (Alternatively, TIKTOK_TOKEN can hold a raw access token for a quick <24h test.)
TIKTOK_TOKEN=""

# Optional counts (defaults: 6 IG, 4 TikTok).
SOCIAL_IG_LIMIT="6"
SOCIAL_TT_LIMIT="4"
